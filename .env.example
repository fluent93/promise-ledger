# Daily Verse English Web Push
# Generate VAPID keys with: npm run push:keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Production subscription storage: Upstash Redis REST.
# Use the HTTPS REST URL and writable Token from the Upstash database page.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local-only fallback storage used by npm run dev:11
LOCAL_PUSH_STORE_FILE=.tmp/daily-verse-subscriptions.json

# Public app path used inside push notifications.
# Keep this as /daily-verse/ unless the production route changes.
DAILY_VERSE_APP_URL=/daily-verse/

# Protect scheduled send endpoints
CRON_SECRET=
